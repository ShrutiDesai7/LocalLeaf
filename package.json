{
  "name": "localleaf-backend",
  "version": "1.0.0",
  "description": "Node.js Express and MySQL backend for the LocalLeaf Nursery Plant Ordering System",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "dev:nodemon": "nodemon app.js",
    "db:init": "node scripts/init-mysql.js",
    "db:check": "node scripts/check-db.js",
    "client:dev": "npm --prefix frontend run dev",
    "client:build": "npm --prefix frontend run build"
  },
  "keywords": [
    "express",
    "mysql",
    "nursery",
    "plants",
    "orders",
    "localleaf"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
